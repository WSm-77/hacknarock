{
  "info": {
    "_postman_id": "d2d8b1dd-7d86-4e4f-b8fb-0a8685f5a0fe",
    "name": "HackNaRock E2E Flow",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": "E2E flow: organizer and participant register/login, organizer creates meeting, participant submits availability, deadline expires, organizer triggers AI recommendation."
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:8000" },
    { "key": "runId", "value": "" },
    { "key": "organizerEmail", "value": "" },
    { "key": "participantEmail", "value": "" },
    { "key": "organizerPassword", "value": "secret123" },
    { "key": "participantPassword", "value": "secret123" },
    { "key": "organizerToken", "value": "" },
    { "key": "participantToken", "value": "" },
    { "key": "meetingId", "value": "" },
    { "key": "publicToken", "value": "" },
    { "key": "blockStart", "value": "" },
    { "key": "blockEnd", "value": "" },
    { "key": "availabilityDeadline", "value": "" },
    { "key": "waitAttempts", "value": "0" }
  ],
  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": [
          "if (!pm.collectionVariables.get('runId')) {",
          "  const runId = Date.now().toString();",
          "  pm.collectionVariables.set('runId', runId);",
          "  pm.collectionVariables.set('organizerEmail', `organizer_${runId}@example.com`);",
          "  pm.collectionVariables.set('participantEmail', `participant_${runId}@example.com`);",
          "}"
        ]
      }
    }
  ],
  "item": [
    {
      "name": "1. Health",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/health",
          "host": ["{{baseUrl}}"],
          "path": ["health"]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Health is OK', function () {",
              "  pm.response.to.have.status(200);",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "2. Register Organizer",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"{{organizerEmail}}\",\n  \"name\": \"Jan\",\n  \"surname\": \"Kowalski\",\n  \"password\": \"{{organizerPassword}}\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/auth/register",
          "host": ["{{baseUrl}}"],
          "path": ["auth", "register"]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Organizer registered', function () {",
              "  pm.response.to.have.status(201);",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "3. Register Participant",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"{{participantEmail}}\",\n  \"name\": \"Anna\",\n  \"surname\": \"Nowak\",\n  \"password\": \"{{participantPassword}}\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/auth/register",
          "host": ["{{baseUrl}}"],
          "path": ["auth", "register"]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Participant registered', function () {",
              "  pm.response.to.have.status(201);",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "4. Login Organizer",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"{{organizerEmail}}\",\n  \"password\": \"{{organizerPassword}}\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/auth/login",
          "host": ["{{baseUrl}}"],
          "path": ["auth", "login"]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Organizer login OK', function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "const body = pm.response.json();",
              "pm.collectionVariables.set('organizerToken', body.access_token);"
            ]
          }
        }
      ]
    },
    {
      "name": "5. Login Participant",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"{{participantEmail}}\",\n  \"password\": \"{{participantPassword}}\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/auth/login",
          "host": ["{{baseUrl}}"],
          "path": ["auth", "login"]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Participant login OK', function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "const body = pm.response.json();",
              "pm.collectionVariables.set('participantToken', body.access_token);"
            ]
          }
        }
      ]
    },
    {
      "name": "6. Organizer /auth/me",
      "request": {
        "method": "GET",
        "header": [
          { "key": "Authorization", "value": "Bearer {{organizerToken}}" }
        ],
        "url": {
          "raw": "{{baseUrl}}/auth/me",
          "host": ["{{baseUrl}}"],
          "path": ["auth", "me"]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Organizer session is valid', function () {",
              "  pm.response.to.have.status(200);",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "7. Create Meeting",
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "type": "text/javascript",
            "exec": [
              "const now = new Date();",
              "const deadline = new Date(now.getTime() + 12000);",
              "const start = new Date(now.getTime() + 3600000);",
              "const end = new Date(now.getTime() + 5400000);",
              "pm.collectionVariables.set('availabilityDeadline', deadline.toISOString());",
              "pm.collectionVariables.set('blockStart', start.toISOString());",
              "pm.collectionVariables.set('blockEnd', end.toISOString());",
              "pm.collectionVariables.set('waitAttempts', '0');"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{organizerToken}}" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"meeting_title\": \"Planowanie wyjazdu\",\n  \"duration_minutes\": 45,\n  \"location\": \"Warszawa\",\n  \"description\": \"Spotkanie organizacyjne\",\n  \"proposed_blocks\": [\n    {\n      \"start_time\": \"{{blockStart}}\",\n      \"end_time\": \"{{blockEnd}}\"\n    }\n  ],\n  \"availability_deadline\": \"{{availabilityDeadline}}\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/meetings",
          "host": ["{{baseUrl}}"],
          "path": ["meetings"]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Meeting created', function () {",
              "  pm.response.to.have.status(201);",
              "});",
              "const body = pm.response.json();",
              "pm.collectionVariables.set('meetingId', body.id);",
              "pm.collectionVariables.set('publicToken', body.public_link.split('/').pop());",
              "pm.test('Meeting has collecting status', function () {",
              "  pm.expect(body.status).to.eql('collecting_availability');",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "8. Submit Participant Availability",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{participantToken}}" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"availability\": {\n    \"available_blocks\": [\n      {\n        \"start_time\": \"{{blockStart}}\",\n        \"end_time\": \"{{blockEnd}}\"\n      }\n    ],\n    \"maybe_blocks\": []\n  }\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/meetings/join/{{publicToken}}/availability",
          "host": ["{{baseUrl}}"],
          "path": ["meetings", "join", "{{publicToken}}", "availability"]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Availability submitted', function () {",
              "  pm.response.to.have.status(200);",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "9. Poll Until Deadline Expires",
      "request": {
        "method": "GET",
        "header": [
          { "key": "Authorization", "value": "Bearer {{organizerToken}}" }
        ],
        "url": {
          "raw": "{{baseUrl}}/meetings/{{meetingId}}",
          "host": ["{{baseUrl}}"],
          "path": ["meetings", "{{meetingId}}"]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Meeting details fetched', function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "const body = pm.response.json();",
              "const attempts = Number(pm.collectionVariables.get('waitAttempts') || '0') + 1;",
              "pm.collectionVariables.set('waitAttempts', String(attempts));",
              "if (body.status !== 'ready_for_ai') {",
              "  if (attempts > 30) {",
              "    pm.test('Deadline transition reached', function () {",
              "      pm.expect.fail('Meeting did not reach ready_for_ai within 30 polls');",
              "    });",
              "  } else {",
              "    postman.setNextRequest('9. Poll Until Deadline Expires');",
              "  }",
              "} else {",
              "  pm.test('Meeting is ready for AI', function () {",
              "    pm.expect(body.status).to.eql('ready_for_ai');",
              "  });",
              "}"
            ]
          }
        }
      ]
    },
    {
      "name": "10. Trigger AI Recommendation",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Authorization", "value": "Bearer {{organizerToken}}" }
        ],
        "url": {
          "raw": "{{baseUrl}}/meetings/{{meetingId}}/ai-recommendation",
          "host": ["{{baseUrl}}"],
          "path": ["meetings", "{{meetingId}}", "ai-recommendation"]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('AI recommendation created', function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "const body = pm.response.json();",
              "pm.test('Meeting moved to ai_recommended', function () {",
              "  pm.expect(body.status).to.eql('ai_recommended');",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "11. Verify Final Meeting State",
      "request": {
        "method": "GET",
        "header": [
          { "key": "Authorization", "value": "Bearer {{organizerToken}}" }
        ],
        "url": {
          "raw": "{{baseUrl}}/meetings/{{meetingId}}",
          "host": ["{{baseUrl}}"],
          "path": ["meetings", "{{meetingId}}"]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Final meeting fetched', function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "const body = pm.response.json();",
              "pm.test('Final state is ai_recommended', function () {",
              "  pm.expect(body.status).to.eql('ai_recommended');",
              "});",
              "pm.test('Votes count is at least 1', function () {",
              "  pm.expect(body.votes_count).to.be.at.least(1);",
              "});"
            ]
          }
        }
      ]
    }
  ]
}

