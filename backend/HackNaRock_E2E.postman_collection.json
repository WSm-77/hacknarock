          "  pm.collectionVariables.set('runId', runId);",
          "  pm.collectionVariables.set('organizerEmail', `organizer_${runId}@example.com`);",
          "  pm.collectionVariables.set('participantEmail', `participant_${runId}@example.com`);",
          "  pm.collectionVariables.set('organizerPassword', 'OrganizerPass123!');",
          "  pm.collectionVariables.set('participantPassword', 'ParticipantPass123!');",
          "  pm.collectionVariables.set('baseUrl', pm.collectionVariables.get('baseUrl') || 'http://localhost:8000');",
          "}",
          ""
        ]
      }
    }
