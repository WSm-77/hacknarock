# PostgreSQL settings used by docker-compose
POSTGRES_DB=hacknarock_testdb
POSTGRES_USER=hacknarock_test_user
POSTGRES_PASSWORD=hacknarock_test_user_password
POSTGRES_PORT=55432

# Backend database connection string (local app -> Docker postgres)
DATABASE_URL=postgresql+psycopg://hacknarock_test_user:hacknarock_test_user_password@localhost:55432/hacknarock_testdb

